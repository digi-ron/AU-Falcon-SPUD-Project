{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch (localhost)",
            "type": "node-terminal",
            "request": "launch",
            "command": "bundle exec jekyll serve --open-url",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Verify Integrity",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/_scripts/site-integrity.ps1",
            "cwd": "${workspaceFolder}"
        }
    ]
}